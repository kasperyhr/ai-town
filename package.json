{
  "name": "ai-town-cloudflare-deepseek",
  "version": "0.8.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:worker": "wrangler dev",
    "build": "tsc --noEmit && vite build",
    "preview": "wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply ai-town-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply ai-town-db --remote",
    "cf:typegen": "wrangler types"
  },
  "dependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "wrangler": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260620.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
